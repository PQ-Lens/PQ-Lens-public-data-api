sudo rm -f /usr/share/keyrings/mongodb-server-8.0.gpg
sudo rm -f /etc/apt/sources.list.d/mongodb-org-8.0.list

sudo apt-get update
sudo apt-get install -y gnupg curl

curl -fsSL https://pgp.mongodb.com/server-8.0.asc | \
  sudo gpg --dearmor -o /usr/share/keyrings/mongodb-server-8.0.gpg

echo "deb [ arch=amd64,arm64 signed-by=/usr/share/keyrings/mongodb-server-8.0.gpg ] https://repo.mongodb.org/apt/ubuntu noble/mongodb-org/8.0 multiverse" | \
  sudo tee /etc/apt/sources.list.d/mongodb-org-8.0.list > /dev/null

cat /etc/apt/sources.list.d/mongodb-org-8.0.list
gpg --show-keys --fingerprint /usr/share/keyrings/mongodb-server-8.0.gpg

sudo apt-get update
sudo apt-get install -y mongodb-org
